<script>
    $(document).ready(function(){
        $('.go-top').on('click',function(event){
            event.preventDefault();
            $('html, body').animate({scrollTop:0},300);
        });

        // modalClickEvent
        $('.side-one-depth div').click(function(e){
            var idx = $(this).attr('data');
            $('.side-one-depth div').removeClass('active');
            $("#"+idx).addClass('active');
        });

        // closeModal
        $(document).mouseup(function(e){
            var modal = $('.side-one-depth div');
            if(modal.hasClass('active')){
                modal.removeClass('active');
            }
        });
    });

    const progressLine = document.querySelector('.autoplay-progress svg')
    const mainSwiper = new Swiper(".main-swiper", {
        pagination: {
            el: ".main-swiper .swiper-pagination",
            clickable: false,
            type: "custom",
            renderCustom: function(swiper, current, total) {
                return (
                    '<span class="current">' + 0 + (current) + '</span>' + '<span class="total">' + 0 + (total) + '</span>'
                );
            }
        },
        navigation: {
            nextEl: ".main-swiper .swiper-button-next",
            prevEl: ".main-swiper .swiper-button-prev",
        },
        on: {
            autoplayTimeLeft(s, time, progress) {
                progressLine.style.setProperty("--progress", 1 - progress)
            }
        }
    });
</script>
